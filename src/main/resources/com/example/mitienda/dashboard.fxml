<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mitienda.DashboardController">

    <left>
        <VBox spacing="10"
              prefWidth="220"
              styleClass="menu">

            <Label text="MITIENDA"/>

            <Button text="🏠 Inicio"/>
            <Button text="📦 Productos"/>
            <Button text="📂 Categorías"/>
            <Button text="👥 Clientes"/>
            <Button text="💰 Ventas"/>
            <Button text="📊 Reportes"/>
            <Button text="⚙ Usuarios"/>

            <Button text="🚪 Cerrar Sesión"
                    onAction="#cerrarSesion"/>

        </VBox>
    </left>

    <center>

        <VBox spacing="15"
              style="-fx-padding:20;">

            <Label text="GESTIÓN DE PRODUCTOS"
                   style="-fx-font-size:20px;
                          -fx-font-weight:bold;"/>

            <GridPane hgap="10"
                      vgap="10">

                <Label text="Código:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtCodigo"
                           promptText="Ingrese código"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Nombre:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtNombre"
                           promptText="Ingrese nombre"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Categoría:"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbCategoria"
                          promptText="Seleccione"
                          GridPane.rowIndex="2"
                          GridPane.columnIndex="1"/>

                <Label text="Precio:"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtPrecio"
                           promptText="0.00"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Stock:"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtStock"
                           promptText="0"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Estado:"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbEstado"
                          promptText="Seleccione"
                          GridPane.rowIndex="5"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Nuevo"
                        onAction="#nuevo"/>

                <Button text="Guardar"
                        onAction="#guardar"/>

                <Button text="Actualizar"
                        onAction="#actualizar"/>

                <Button text="Eliminar"
                        onAction="#eliminar"/>

                <Button text="Limpiar"
                        onAction="#limpiar"/>

            </HBox>

            <TableView fx:id="tablaProductos"
                       prefHeight="350">

                <columns>

                    <TableColumn fx:id="colCodigo"
                                 text="Código"
                                 prefWidth="100"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colCategoria"
                                 text="Categoría"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colPrecio"
                                 text="Precio"
                                 prefWidth="100"/>

                    <TableColumn fx:id="colStock"
                                 text="Stock"
                                 prefWidth="100"/>

                    <TableColumn fx:id="colEstado"
                                 text="Estado"
                                 prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>